# ─────────────────────────────────────────────────────────────────────────────
# Contracts API automation — environment configuration
# Copy this file to `.env` and fill in real values for local runs.
# `.env` is gitignored and MUST NOT be committed. In CI, set these as GitHub
# Actions repository secrets (see .github/workflows/api-tests.yml).
# ─────────────────────────────────────────────────────────────────────────────

# Which environment to target: "sandbox" or "uat".
CONTRACTS_ENV=sandbox

# ── Credentials (per environment) ────────────────────────────────────────────
# Provided on the API Configuration tab inside the APIs Settings page.
CONTRACTS_CLIENT_ID=
CONTRACTS_API_KEY=
CONTRACTS_SECRET_KEY=

# ── Base URLs (optional overrides) ───────────────────────────────────────────
# Defaults live in src/client/config.ts. Override here if the URLs change.
# SANDBOX_BASE_URL=https://api-sb.contracts.com.sa
# UAT_BASE_URL=https://<your-uat-host>

# ── Seed data for endpoints that need a Nafath-signed contract ───────────────
# Leave blank to skip happy-path tests for these endpoints (negatives still run).
SIGNED_CONTRACT_NUMBER=
SIGNED_ADDENDUM_REF=
SANAD_GROUP_UUID=
NAFATH_TRACE_ID=

# ── Seed data for read/query happy-paths (optional) ──────────────────────────
# An existing contract number + a beneficiary national id that has contracts.
EXISTING_CONTRACT_NUMBER=
EXISTING_BENEFICIARY_NID=

# ── Notifications (CI only) ──────────────────────────────────────────────────
# Slack Incoming Webhook URL; failures post here from GitHub Actions.
SLACK_WEBHOOK_URL=
